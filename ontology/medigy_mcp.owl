  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#data_provenance">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT id, title, link, version_year, ingested_at, object_type, description FROM data_provenance</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#executive_kpis">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT total_conditions, total_states, total_procedures, total_beneficiaries, total_allowed_amt, total_medicare_payment, active_data_sources FROM executive_kpis</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#opportunity_score">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, specialty_domain, tier, total_benes, total_allowed, opportunity_score FROM opportunity_score ORDER BY opportunity_score DESC LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#top_states_by_condition">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, state_abbr, total_beneficiaries, total_allowed_amt, allowed_per_patient, state_rank FROM top_states_by_condition ORDER BY state_rank LIMIT 100</mcpQueryHint>
