  <!-- ═══ MCP QUERY HINTS ═══ -->
  <owl:AnnotationProperty rdf:about="http://medigy.ontology/surveilr#mcpQueryHint">
    <rdfs:label>MCP Query Hint</rdfs:label>
    <rdfs:comment>Example SQL SELECT for MCP agents to retrieve data from this table/view</rdfs:comment>
  </owl:AnnotationProperty>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#fact_utilization_unified">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT source_type, state_abbr, hcpcs_code, condition_name, body_system, specialty_domain, tier, total_beneficiaries, total_services FROM fact_utilization_unified LIMIT 100</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_condition_registry">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_id, condition_name, body_system, tier FROM dim_condition_registry</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_procedure">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT hcpcs_code, procedure_description, procedure_category, procedure_signal, linked_condition FROM dim_procedure</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_diagnosis">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT icd10_code, diagnosis_description, disease_state, body_system FROM dim_diagnosis</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_specialty">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT raw_specialty_name, specialty_name, specialty_domain FROM dim_specialty</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_geography">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT state_abbr, mac_name, locality_name, pw_gpci, cost_tier FROM dim_geography</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_condition_national_summary">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, specialty_domain, tier, opportunity_score, states_with_data, total_beneficiaries, total_services, total_allowed_amt FROM mat_condition_national_summary ORDER BY opportunity_score DESC LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_opportunity_score">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, specialty_domain, tier, total_benes, total_allowed, opportunity_score FROM mat_opportunity_score ORDER BY opportunity_score DESC LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_executive_kpis">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT total_conditions, total_states, total_procedures, total_beneficiaries, total_allowed_amt, total_medicare_payment, active_data_sources FROM mat_executive_kpis</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_condition_state_breakdown">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, state_abbr, locality_name, cost_tier, pw_gpci, total_beneficiaries, total_allowed_amt, allowed_per_patient FROM mat_condition_state_breakdown LIMIT 100</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_condition_hcpcs_detail">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, hcpcs_code, procedure_description, procedure_category, source_type, total_beneficiaries, total_services, total_allowed_amt, avg_allowed_per_service FROM mat_condition_hcpcs_detail LIMIT 100</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_top_states_by_condition">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, state_abbr, total_beneficiaries, total_allowed_amt, allowed_per_patient, state_rank FROM mat_top_states_by_condition ORDER BY state_rank LIMIT 100</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#mat_condition_source_breakdown">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT condition_name, source_type, total_beneficiaries, total_services, total_allowed_amt, total_medicare_payment FROM mat_condition_source_breakdown LIMIT 100</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_cms_provider">
