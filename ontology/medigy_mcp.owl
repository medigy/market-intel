<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns="http://medigy.ontology/surveilr#"
  xml:base="http://medigy.ontology/surveilr#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

  <owl:Ontology rdf:about="http://medigy.ontology/surveilr#">
    <rdfs:label>resource-surveillance (surveilr) TBox Schema Ontology</rdfs:label>
    <rdfs:comment>Pure TBox (schema-only) OWL for MCP chat. 135 tables + 50 views + 62 FK object properties. No ABox instance data — MCP server queries live SQLite at runtime. All rdf:about IRIs are safe ASCII; original names preserved in rdfs:label. Primary join: fact_utilization links to dim_procedure (hcpcs_code), dim_specialty (specialty_name), dim_geography (state_abbr).</rdfs:comment>
    <owl:versionInfo>2.0</owl:versionInfo>
  </owl:Ontology>

  <!-- ═══ ABSTRACT DOMAIN CLASSES (groupings only, not SQL tables) ═══ -->
  <owl:Class rdf:about="http://medigy.ontology/surveilr#CMSAggregation">
    <rdfs:label>CMSAggregation</rdfs:label>
    <rdfs:comment>CMS aggregated data: by geography, by provider, place-of-service mapping</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ClinicalAnalytic">
    <rdfs:label>ClinicalAnalytic</rdfs:label>
    <rdfs:comment>Derived clinical analytic tables: disease bridges, monitoring intensity, DME metrics</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ClinicalDimension">
    <rdfs:label>ClinicalDimension</rdfs:label>
    <rdfs:comment>Dimension tables for clinical analysis: procedure, diagnosis, specialty, geography</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ClinicalFact">
    <rdfs:label>ClinicalFact</rdfs:label>
    <rdfs:comment>Core fact table capturing utilization events (services, beneficiaries, payments)</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ClinicalReference">
    <rdfs:label>ClinicalReference</rdfs:label>
    <rdfs:comment>CMS/HCPCS/ICD-10/DME reference code and pricing tables</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#CodeNotebook">
    <rdfs:label>CodeNotebook</rdfs:label>
    <rdfs:comment>Named SQL/script cells and kernels for migration and scheduled execution</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#DeviceEntity">
    <rdfs:label>DeviceEntity</rdfs:label>
    <rdfs:comment>Physical/virtual device identity and device-party relationships</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#MarketAnalytics">
    <rdfs:label>MarketAnalytics</rdfs:label>
    <rdfs:comment>Market dynamics, MDSD models, specialty and economic analytics</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#Orchestration">
    <rdfs:label>Orchestration</rdfs:label>
    <rdfs:comment>Orchestration sessions, execution steps, logs, issues, and state transitions</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#OsquerySNMP">
    <rdfs:label>OsquerySNMP</rdfs:label>
    <rdfs:comment>osquery management server nodes, carves, distributed queries, and SNMP collections</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#PartyEntity">
    <rdfs:label>PartyEntity</rdfs:label>
    <rdfs:comment>Party model: persons, organizations, roles, and relationships</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#PolicyMonitoring">
    <rdfs:label>PolicyMonitoring</rdfs:label>
    <rdfs:comment>Assurance schemas, behaviors, osquery policies, monitoring proxies, data provenance</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ResourceIngestion">
    <rdfs:label>ResourceIngestion</rdfs:label>
    <rdfs:comment>Uniform resource ingestion pipeline: filesystem, IMAP, tasks, transforms</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#SummaryAnalytics">
    <rdfs:label>SummaryAnalytics</rdfs:label>
    <rdfs:comment>Pre-computed summary tables for charts, narratives, and benchmarks (MCP-ready outputs)</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#Utility">
    <rdfs:label>Utility</rdfs:label>
    <rdfs:comment>Internal utility: sqlpage navigation, function docs, sequence, ephemeral state</rdfs:comment>
  </owl:Class>

  <!-- ═══ TABLE CLASSES (each maps 1:1 to a SQLite table) ═══ -->
  <owl:Class rdf:about="http://medigy.ontology/surveilr#assurance_schema">
    <rdfs:label>assurance_schema</rdfs:label>
    <rdfs:comment>SQLite table: assurance_schema | PK: assurance_schema_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PolicyMonitoring"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#behavior">
    <rdfs:label>behavior</rdfs:label>
    <rdfs:comment>SQLite table: behavior | PK: behavior_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PolicyMonitoring"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#chronic_interaction_density">
    <rdfs:label>chronic_interaction_density</rdfs:label>
    <rdfs:comment>SQLite table: chronic_interaction_density</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#code_notebook_cell">
    <rdfs:label>code_notebook_cell</rdfs:label>
    <rdfs:comment>Named SQL/script cells. notebook_kernel_id links to code_notebook_kernel for runtime type | PK: code_notebook_cell_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#CodeNotebook"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#code_notebook_kernel">
    <rdfs:label>code_notebook_kernel</rdfs:label>
    <rdfs:comment>SQLite table: code_notebook_kernel | PK: code_notebook_kernel_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#CodeNotebook"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#code_notebook_state">
    <rdfs:label>code_notebook_state</rdfs:label>
    <rdfs:comment>SQLite table: code_notebook_state | PK: code_notebook_state_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#CodeNotebook"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#condition_monitoring_proxy_table">
    <rdfs:label>condition_monitoring_proxy_table</rdfs:label>
    <rdfs:comment>SQLite table: condition_monitoring_proxy_table</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PolicyMonitoring"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#data_provenance">
    <rdfs:label>data_provenance</rdfs:label>
    <rdfs:comment>Tracks data lineage and source attribution for ingested resources | PK: id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PolicyMonitoring"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#device">
    <rdfs:label>device</rdfs:label>
    <rdfs:comment>Device identity: hostname, state boundary. Root entity for ingestion and orchestration | PK: device_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#DeviceEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#device_party_relationship">
    <rdfs:label>device_party_relationship</rdfs:label>
    <rdfs:comment>SQLite table: device_party_relationship | PK: device_party_relationship_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#DeviceEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_diagnosis">
    <rdfs:label>dim_diagnosis</rdfs:label>
    <rdfs:comment>Diagnosis dimension. icd10_code joins to uniform_resource_ref_icd10_diagnosis and disease_procedure_bridge</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalDimension"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_geography">
    <rdfs:label>dim_geography</rdfs:label>
    <rdfs:comment>Geography dimension. state_abbr joins to fact_utilization and uniform_resource_ref_geo_adjustment</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalDimension"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_procedure">
    <rdfs:label>dim_procedure</rdfs:label>
    <rdfs:comment>Procedure dimension. hcpcs_code is the join key to fact_utilization and most reference tables</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalDimension"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_specialty">
    <rdfs:label>dim_specialty</rdfs:label>
    <rdfs:comment>Specialty dimension. specialty_name joins to fact_utilization and uniform_resource_cms_provider</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalDimension"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#disease_procedure_bridge">
    <rdfs:label>disease_procedure_bridge</rdfs:label>
    <rdfs:comment>SQLite table: disease_procedure_bridge</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#disease_state_icd_coverage">
    <rdfs:label>disease_state_icd_coverage</rdfs:label>
    <rdfs:comment>SQLite table: disease_state_icd_coverage</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dme_supply_refill_metrics">
    <rdfs:label>dme_supply_refill_metrics</rdfs:label>
    <rdfs:comment>SQLite table: dme_supply_refill_metrics</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#facility_vs_office_split">
    <rdfs:label>facility_vs_office_split</rdfs:label>
    <rdfs:comment>SQLite table: facility_vs_office_split</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#fact_utilization">
    <rdfs:label>fact_utilization</rdfs:label>
    <rdfs:comment>PRIMARY FACT TABLE. JoinKeys: hcpcs_code→dim_procedure.hcpcs_code, specialty_name→dim_specialty.specialty_name, state_abbr→dim_geography.state_abbr, place_of_service_code→uniform_resource_cms_bygeo_place_of_service_mapping.pos_code</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalFact"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#gender_type">
    <rdfs:label>gender_type</rdfs:label>
    <rdfs:comment>SQLite table: gender_type | PK: gender_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#geographic_market_opportunity">
    <rdfs:label>geographic_market_opportunity</rdfs:label>
    <rdfs:comment>SQLite table: geographic_market_opportunity</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#master_evidence_hub">
    <rdfs:label>master_evidence_hub</rdfs:label>
    <rdfs:comment>Central evidence table linking procedures, diagnoses, specialties, and payer context</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#mdsd_condition_deep_dive">
    <rdfs:label>mdsd_condition_deep_dive</rdfs:label>
    <rdfs:comment>SQLite table: mdsd_condition_deep_dive</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#mdsd_economic_intensity_proof">
    <rdfs:label>mdsd_economic_intensity_proof</rdfs:label>
    <rdfs:comment>SQLite table: mdsd_economic_intensity_proof</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#mdsd_global_opportunity_matrix">
    <rdfs:label>mdsd_global_opportunity_matrix</rdfs:label>
    <rdfs:comment>SQLite table: mdsd_global_opportunity_matrix</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#mdsd_interaction_model_fit">
    <rdfs:label>mdsd_interaction_model_fit</rdfs:label>
    <rdfs:comment>SQLite table: mdsd_interaction_model_fit</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#mdsd_specialty_gatekeepers">
    <rdfs:label>mdsd_specialty_gatekeepers</rdfs:label>
    <rdfs:comment>SQLite table: mdsd_specialty_gatekeepers</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#MarketAnalytics"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#monitoring_procedure_intensity">
    <rdfs:label>monitoring_procedure_intensity</rdfs:label>
    <rdfs:comment>SQLite table: monitoring_procedure_intensity</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#opportunity_scoring_view">
    <rdfs:label>opportunity_scoring_view</rdfs:label>
    <rdfs:comment>SQLite table: opportunity_scoring_view</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_nature">
    <rdfs:label>orchestration_nature</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_nature | PK: orchestration_nature_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session">
    <rdfs:label>orchestration_session</rdfs:label>
    <rdfs:comment>Top-level orchestration run. Links to device, nature, entries, exec steps, logs, issues | PK: orchestration_session_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_entry">
    <rdfs:label>orchestration_session_entry</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_session_entry | PK: orchestration_session_entry_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_exec">
    <rdfs:label>orchestration_session_exec</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_session_exec | PK: orchestration_session_exec_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_issue">
    <rdfs:label>orchestration_session_issue</rdfs:label>
    <rdfs:comment>Issues/errors from orchestration. Join to orchestration_session via session_id | PK: orchestration_session_issue_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_issue_relation">
    <rdfs:label>orchestration_session_issue_relation</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_session_issue_relation | PK: orchestration_session_issue_relation_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_log">
    <rdfs:label>orchestration_session_log</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_session_log | PK: orchestration_session_log_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_state">
    <rdfs:label>orchestration_session_state</rdfs:label>
    <rdfs:comment>SQLite table: orchestration_session_state | PK: orchestration_session_state_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Orchestration"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#organization">
    <rdfs:label>organization</rdfs:label>
    <rdfs:comment>SQLite table: organization | PK: organization_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#organization_role">
    <rdfs:label>organization_role</rdfs:label>
    <rdfs:comment>SQLite table: organization_role | PK: organization_role_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#organization_role_type">
    <rdfs:label>organization_role_type</rdfs:label>
    <rdfs:comment>SQLite table: organization_role_type | PK: organization_role_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#osquery_policy">
    <rdfs:label>osquery_policy</rdfs:label>
    <rdfs:comment>SQLite table: osquery_policy | PK: osquery_policy_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PolicyMonitoring"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#part_b_drug_intensity">
    <rdfs:label>part_b_drug_intensity</rdfs:label>
    <rdfs:comment>SQLite table: part_b_drug_intensity</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#ClinicalAnalytic"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#party">
    <rdfs:label>party</rdfs:label>
    <rdfs:comment>SQLite table: party | PK: party_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#party_relation">
    <rdfs:label>party_relation</rdfs:label>
    <rdfs:comment>SQLite table: party_relation | PK: party_relation_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#party_relation_type">
    <rdfs:label>party_relation_type</rdfs:label>
    <rdfs:comment>SQLite table: party_relation_type | PK: party_relation_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#party_type">
    <rdfs:label>party_type</rdfs:label>
    <rdfs:comment>SQLite table: party_type | PK: party_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#person">
    <rdfs:label>person</rdfs:label>
    <rdfs:comment>SQLite table: person | PK: person_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#person_type">
    <rdfs:label>person_type</rdfs:label>
    <rdfs:comment>SQLite table: person_type | PK: person_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#session_state_ephemeral">
    <rdfs:label>session_state_ephemeral</rdfs:label>
    <rdfs:comment>SQLite table: session_state_ephemeral | PK: key</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#Utility"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#sex_type">
    <rdfs:label>sex_type</rdfs:label>
    <rdfs:comment>SQLite table: sex_type | PK: sex_type_id</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://medigy.ontology/surveilr#PartyEntity"/>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#specialty_activity_summary">
