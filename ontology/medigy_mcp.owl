  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_cms_bygeography">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT Rndrng_Prvdr_Geo_Lvl, Rndrng_Prvdr_Geo_Desc, HCPCS_Cd, HCPCS_Desc, Place_Of_Srvc, Tot_Benes FROM uniform_resource_cms_bygeography LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_ref_procedure_code">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT HCPCS, MOD, DESCRIPTION, "STATUS CODE", "MEDICARE PAYMENT", "WORK RVU", "NON-FAC PE RVU", "FACILITY PE RVU" FROM uniform_resource_ref_procedure_code LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_ref_rvu_qpp">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT HCPCS, MOD, DESCRIPTION, "MEDICARE PAYMENT", "WORK RVU" FROM uniform_resource_ref_rvu_qpp LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_dme_data">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT Rfrg_NPI, Rfrg_Prvdr_Last_Name_Org, Rfrg_Prvdr_First_Name FROM uniform_resource_dme_data LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_dme_cpap_e0601_e0470_e0471">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT Rfrg_NPI, Rfrg_Prvdr_Last_Name_Org, Rfrg_Prvdr_First_Name FROM uniform_resource_dme_cpap_e0601_e0470_e0471 LIMIT 50</mcpQueryHint>
  </owl:Class>

  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_copd_oxygen">
