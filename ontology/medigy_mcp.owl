  <!-- ═══ MCP QUERY HINTS ═══ -->
  <owl:AnnotationProperty rdf:about="http://medigy.ontology/surveilr#mcpQueryHint">
    <rdfs:label>MCP Query Hint</rdfs:label>
    <rdfs:comment>Example SQL SELECT for MCP agents to retrieve data from this table/view</rdfs:comment>
  </owl:AnnotationProperty>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#fact_utilization">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT specialty_name, hcpcs_code, state_abbr, place_of_service_code, total_beneficiaries, total_services, total_medicare_payment FROM fact_utilization LIMIT 100</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_procedure">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT hcpcs_code, procedure_description, procedure_category, procedure_signal, is_monitoring_flag FROM dim_procedure</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_diagnosis">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT icd10_code, diagnosis_description, disease_state, body_system FROM dim_diagnosis</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_specialty">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT specialty_name, specialty_domain FROM dim_specialty</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#dim_geography">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT state_abbr, mac_name, locality_name, pw_gpci, cost_tier FROM dim_geography</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT uniform_resource_id, uri, content_type, size_bytes, created_at FROM uniform_resource LIMIT 50</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT orchestration_session_id, device_id, created_at FROM orchestration_session LIMIT 20</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#orchestration_session_issue">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT issue_type, issue_message, session_id FROM orchestration_session_issue LIMIT 20</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#code_notebook_cell">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT notebook_name, cell_name, interpretable_code FROM code_notebook_cell</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_cms_provider">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT Rndrng_NPI, Rndrng_Prvdr_Type, Tot_Srvcs, Tot_Mdcr_Pymt_Amt FROM uniform_resource_cms_provider LIMIT 50</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#uniform_resource_ref_procedure_code">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT HCPCS, DESCRIPTION, WORK_RVU, FACILITY_TOTAL FROM uniform_resource_ref_procedure_code LIMIT 50</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#master_evidence_hub">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT * FROM master_evidence_hub LIMIT 20</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#specialty_market_dynamics">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT * FROM specialty_market_dynamics LIMIT 20</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#summary_market_overview">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT * FROM summary_market_overview</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#summary_specialty_narrative">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT * FROM summary_specialty_narrative</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#device">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT device_id, name, state FROM device</mcpQueryHint>
  </owl:Class>
  <owl:Class rdf:about="http://medigy.ontology/surveilr#ur_ingest_session">
    <mcpQueryHint xmlns="http://medigy.ontology/surveilr#">SELECT ur_ingest_session_id, device_id, behavior_id, created_at FROM ur_ingest_session LIMIT 20</mcpQueryHint>
  </owl:Class>

